@model FilmRentalStore.MVC.ViewModels.Payment.PaymentViewModel

<h1>Payment Details</h1>

<div class="card p-3">
    <p><strong>Payment Id:</strong> @Model.PaymentId</p>
    <p><strong>Customer Id:</strong> @Model.CustomerId</p>
    <p><strong>Rental Id:</strong> @Model.RentalId</p>
    <p><strong>Amount:</strong> @Model.Amount</p>
    <p><strong>Payment Date:</strong> @Model.PaymentDate</p>
</div>

<a asp-action="Index" class="btn btn-secondary mt-3">Back</a>