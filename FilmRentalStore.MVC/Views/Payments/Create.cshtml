@model FilmRentalStore.MVC.ViewModels.Payment.PaymentViewModel

<h1>Create Payment</h1>

<form asp-action="Create" method="post">

    <div class="mb-3">
        <label asp-for="CustomerId" class="form-label"></label>
        <input asp-for="CustomerId" class="form-control" />
        <span asp-validation-for="CustomerId" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="RentalId" class="form-label"></label>
        <input asp-for="RentalId" class="form-control" />
        <span asp-validation-for="RentalId" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Amount" class="form-label"></label>
        <input asp-for="Amount" class="form-control" />
        <span asp-validation-for="Amount" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-primary">Create Payment</button>
</form>