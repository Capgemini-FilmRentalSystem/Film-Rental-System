@model List<FilmRentalStore.MVC.DTOs.Payment.PaymentResponseDto>

@{
    ViewData["Title"] = (bool)(ViewBag.IsMine ?? false) ? "My Payments" : "Payments";
    var isMine = (bool)(ViewBag.IsMine ?? false);
    var currentPage = (int)(ViewBag.CurrentPage ?? 1);
    var pageSize = (int)(ViewBag.PageSize ?? 10);
    var hasNextPage = (bool)(ViewBag.HasNextPage ?? false);
    var listAction = isMine ? "MyPayments" : "Index";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1>@ViewData["Title"]</h1>
    @if (!isMine)
    {
        <a asp-action="Create" class="btn btn-primary">Create Payment</a>
    }
</div>

<div class="table-responsive">
    <table class="table table-hover align-middle">
        <thead class="table-light">
            <tr>
                <th>ID</th>
                <th>Customer</th>
                <th>Staff</th>
                <th>Amount</th>
                <th>Payment Date</th>
                <th class="text-end">Actions</th>
            </tr>
        </thead>
        <tbody>
            @if (Model.Any())
            {
                foreach (var payment in Model)
                {
                    <tr>
                        <td>@payment.PaymentId</td>
                        <td>@payment.Customer?.FullName</td>
                        <td>@payment.Staff?.FullName</td>
                        <td>@payment.Amount.ToString("C")</td>
                        <td>@payment.PaymentDate.ToString("g")</td>
                        <td class="text-end">
                            <a asp-action="@(isMine ? "MyDetails" : "Details")" asp-route-id="@payment.PaymentId" class="btn btn-sm btn-info">Details</a>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="6" class="text-center text-muted">No payments found.</td>
                </tr>
            }
        </tbody>
    </table>
</div>

<nav>
    <ul class="pagination">
        <li class="page-item @(currentPage <= 1 ? "disabled" : "")">
            <a class="page-link" asp-action="@listAction" asp-route-page="@(currentPage - 1)" asp-route-pageSize="@pageSize">Previous</a>
        </li>
        <li class="page-item disabled"><span class="page-link">Page @currentPage</span></li>
        <li class="page-item @(hasNextPage ? "" : "disabled")">
            <a class="page-link" asp-action="@listAction" asp-route-page="@(currentPage + 1)" asp-route-pageSize="@pageSize">Next</a>
        </li>
    </ul>
</nav>
