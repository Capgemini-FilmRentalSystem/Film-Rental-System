@model FilmRentalStore.MVC.ViewModels.Language.LanguageDetailsViewModel

@{
    ViewData["Title"] = "Language Details";
    var role = Context.Session.GetString(SessionKeys.Role);
    var canManageLanguages = role == RoleConstants.Admin || role == RoleConstants.Manager;
}

<div class="container-fluid">
    <div class="row mb-3">
        <div class="col-md-8">
            <h1>Language Details</h1>
        </div>
        <div class="col-md-4 text-end">
            <a href="@Url.Action("Index")" class="btn btn-secondary">Back to List</a>
            @if (canManageLanguages)
            {
                <a href="@Url.Action("Edit", new { id = Model.Language?.LanguageId })" class="btn btn-warning">Edit</a>
            }
        </div>
    </div>

    @if (Model.Language != null)
    {
        <div class="card">
            <div class="card-body">
                <div class="row mb-3">
                    <div class="col-md-6">
                        <label class="form-label"><strong>Name:</strong></label>
                        <p>@Model.Language.Name</p>
                    </div>
                </div>
                <div class="row">
                    <div class="col-md-12">
                        <small class="text-muted">
                            Last Updated: @Model.Language.LastUpdate.ToString("g")
                        </small>
                    </div>
                </div>
            </div>
        </div>
    }

    <h3 class="mt-4">Films</h3>

    @if (Model.Films.Any())
    {
        <div class="table-responsive">
            <table class="table table-hover">
                <thead class="table-light">
                    <tr>
                        <th>Title</th>
                        <th>Release Year</th>
                        <th>Rating</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var film in Model.Films)
                    {
                        <tr>
                            <td>@film.Title</td>
                            <td>@(film.ReleaseYear ?? "-")</td>
                            <td>@(film.Rating ?? "-")</td>
                            <td class="text-end">
                                <a asp-controller="Films" asp-action="Details" asp-route-id="@film.FilmId" class="btn btn-sm btn-info">View</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <p class="text-muted">No films found for this language.</p>
    }
</div>
