@model FilmRentalStore.MVC.ViewModels.Film.FilmIndexViewModel

@{
    ViewData["Title"] = "Films";
    var role = Context.Session.GetString(SessionKeys.Role);
    var canManageFilms = role == RoleConstants.Admin || role == RoleConstants.Manager;
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Films</h2>
    @if (canManageFilms)
    {
        <a asp-action="Create" class="btn btn-primary">+ Add Film</a>
    }
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}

<form method="get" class="row g-2 mb-3">
    <div class="col-md-5">
        <input name="searchTerm" class="form-control" value="@Model.SearchTerm" placeholder="Search films" />
    </div>
    <div class="col-md-auto">
        <button type="submit" class="btn btn-secondary">Search</button>
    </div>
    @if (!string.IsNullOrWhiteSpace(Model.SearchTerm))
    {
        <div class="col-md-auto">
            <a asp-action="Index" class="btn btn-outline-secondary">Clear</a>
        </div>
    }
</form>

<table class="table table-bordered table-hover">
    <thead class="table-dark">
        <tr>
            <th>Title</th>
            <th>Language</th>
            <th>Rating</th>
            <th>Rental Rate</th>
            <th>Duration (days)</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var film in Model.Films)
        {
            <tr>
                <td>@film.Title</td>
                <td>@film.Language?.Name</td>
                <td>@film.Rating</td>
                <td>$@film.RentalRate</td>
                <td>@film.RentalDuration</td>
                <td>
                    <a asp-action="Details" asp-route-id="@film.FilmId" class="btn btn-sm btn-info">Details</a>
                    @if (canManageFilms)
                    {
                        <a asp-action="Edit" asp-route-id="@film.FilmId" class="btn btn-sm btn-warning">Edit</a>
                    }
                </td>
            </tr>
        }
        @if (!Model.Films.Any())
        {
            <tr>
                <td colspan="6" class="text-center text-muted">No films found.</td>
            </tr>
        }
    </tbody>
</table>

<nav>
    <ul class="pagination">
        @if (Model.CurrentPage > 1)
        {
            <li class="page-item">
                <a class="page-link" asp-action="Index"
                   asp-route-page="@(Model.CurrentPage - 1)"
                   asp-route-pageSize="@Model.PageSize"
                   asp-route-searchTerm="@Model.SearchTerm">Previous</a>
            </li>
        }
        <li class="page-item disabled">
            <span class="page-link">Page @Model.CurrentPage</span>
        </li>
        @if (Model.HasNextPage)
        {
            <li class="page-item">
                <a class="page-link" asp-action="Index"
                   asp-route-page="@(Model.CurrentPage + 1)"
                   asp-route-pageSize="@Model.PageSize"
                   asp-route-searchTerm="@Model.SearchTerm">Next</a>
            </li>
        }
    </ul>
</nav>
