@model IEnumerable<FilmRentalStore.MVC.ViewModels.Actor.ActorViewModel>

<h1>Actors</h1>

<a asp-action="Create" class="btn btn-primary">Create Actor</a>

<table class="table mt-3">
    <thead>
        <tr>
            <th>Actor Id</th>
            <th>First Name</th>
            <th>Last Name</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var actor in Model)
        {
            <tr>
                <td>@actor.ActorId</td>
                <td>@actor.FirstName</td>
                <td>@actor.LastName</td>
                <td>
                    <a asp-action="Details" asp-route-id="@actor.ActorId">Details</a> |
                    <a asp-action="Edit" asp-route-id="@actor.ActorId">Edit</a>
                </td>
            </tr>
        }
    </tbody>
</table>