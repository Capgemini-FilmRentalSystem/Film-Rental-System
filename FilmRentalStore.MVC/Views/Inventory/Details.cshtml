@model FilmRentalStore.MVC.DTOs.Inventory.InventoryResponseDto

@{
    ViewData["Title"] = "Inventory Details";
    var role = Context.Session.GetString(SessionKeys.Role);
    var canManageInventory = role == RoleConstants.Admin || role == RoleConstants.Manager;
    var canSeeStoreId = role == RoleConstants.Admin;
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1>Inventory Details</h1>
    <div>
        @if (canManageInventory)
        {
            <a asp-action="Edit" asp-route-id="@Model.InventoryId" class="btn btn-warning">Edit</a>
        }
        <a asp-action="Index" class="btn btn-secondary">Back</a>
    </div>
</div>

<dl class="row">
    <dt class="col-sm-3">Inventory ID</dt>
    <dd class="col-sm-9">@Model.InventoryId</dd>
    <dt class="col-sm-3">Film</dt>
    <dd class="col-sm-9">@Model.Film?.Title (@Model.FilmId)</dd>
    @if (canSeeStoreId)
    {
        <dt class="col-sm-3">Store ID</dt>
        <dd class="col-sm-9">@Model.StoreId</dd>
    }
    <dt class="col-sm-3">Status</dt>
    <dd class="col-sm-9">@(Model.IsAvailable ? "Available" : "Rented")</dd>
    <dt class="col-sm-3">Last Updated</dt>
    <dd class="col-sm-9">@Model.LastUpdate.ToString("g")</dd>
</dl>
