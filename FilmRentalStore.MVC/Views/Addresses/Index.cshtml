@model FilmRentalStore.MVC.ViewModels.Address.AddressIndexViewModel

@{
    ViewData["Title"] = "Addresses";
    var role = Context.Session.GetString(SessionKeys.Role);
    var canManageAddresses = role == RoleConstants.Admin || role == RoleConstants.Manager || role == RoleConstants.Staff;
    var currentPage = Model.CurrentPage;
    var pageSize = Model.PageSize;
    var hasNextPage = Model.Addresses.Count == pageSize;
}

<div class="container-fluid">
    <div class="row mb-3">
        <div class="col-md-8">
            <h1>Addresses</h1>
        </div>
        <div class="col-md-4 text-end">
            @if (canManageAddresses)
            {
                <a href="@Url.Action("Create")" class="btn btn-primary">+ New Address</a>
            }
        </div>
    </div>

    <div class="card">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-hover">
                    <thead class="table-light">
                        <tr>
                            <th>Address</th>
                            <th>City</th>
                            <th>District</th>
                            <th>Phone</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.Addresses.Any())
                        {
                            @foreach (var address in Model.Addresses)
                            {
                                <tr>
                                    <td>@address.AddressLine</td>
                                    <td>@address.City</td>
                                    <td>@address.District</td>
                                    <td>@address.Phone</td>
                                    <td>
                                        <a href="@Url.Action("Details", new { id = address.AddressId })" class="btn btn-sm btn-info">View</a>
                                        @if (canManageAddresses)
                                        {
                                            <a href="@Url.Action("Edit", new { id = address.AddressId })" class="btn btn-sm btn-warning">Edit</a>
                                            <form method="post" action="@Url.Action("Delete", new { id = address.AddressId })" style="display:inline;">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="btn btn-sm btn-danger" onclick="return confirm('Are you sure?');">Delete</button>
                                            </form>
                                        }
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="5" class="text-center text-muted">No addresses found</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            <nav aria-label="Addresses pagination">
                <ul class="pagination mb-0">
                    <li class="page-item @(currentPage > 1 ? "" : "disabled")">
                        <a class="page-link" asp-action="Index" asp-route-page="@(currentPage - 1)" asp-route-pageSize="@pageSize">Previous</a>
                    </li>
                    <li class="page-item disabled">
                        <span class="page-link">Page @currentPage</span>
                    </li>
                    <li class="page-item @(hasNextPage ? "" : "disabled")">
                        <a class="page-link" asp-action="Index" asp-route-page="@(currentPage + 1)" asp-route-pageSize="@pageSize">Next</a>
                    </li>
                </ul>
            </nav>
        </div>
    </div>
</div>
