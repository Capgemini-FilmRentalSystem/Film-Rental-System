@model FilmRentalStore.MVC.ViewModels.Auth.LoginViewModel

@{
    ViewData["Title"] = "Customer Login";
    Layout = "_Layout";
}

<div class="row justify-content-center">
    <div class="col-md-5">
        <div class="card shadow-sm">
            <div class="card-header">
                <h4 class="mb-0">Customer Login</h4>
            </div>

            <div class="card-body">
                <partial name="_Alert" />

                <form asp-action="CustomerLogin" asp-controller="Auth" method="post">
                    @Html.AntiForgeryToken()

                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="mb-3">
                        <label asp-for="Username" class="form-label"></label>
                        <input asp-for="Username" class="form-control" />
                        <span asp-validation-for="Username" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Password" class="form-label"></label>
                        <input asp-for="Password" class="form-control" />
                        <span asp-validation-for="Password" class="text-danger"></span>
                    </div>

                    <button type="submit" class="btn btn-primary w-100">Login</button>
                </form>

                <div class="mt-3 text-center">
                    <a asp-controller="Auth" asp-action="CustomerRegister">Register as Customer</a>
                    <span class="mx-2">|</span>
                    <a asp-controller="Auth" asp-action="StaffLogin">Login as Staff</a>
                </div>
            </div>
        </div>
    </div>
</div>
